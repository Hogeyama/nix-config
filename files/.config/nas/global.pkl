// ---------------------------------------------------------------------------
// 共通ブロック（各プロファイルから参照される共有設定）
// ---------------------------------------------------------------------------

amends "Schema.pkl"

local commonEnv: Listing<EnvConfig> = new {
  new { key = "TZ"; val = "Asia/Tokyo" }
  new { key = "LANG"; val = "en_US.UTF-8" }
  // hostexecのgpgで署名する
  new { key = "GIT_CONFIG_COUNT"; val = "1" }
  new { key = "GIT_CONFIG_KEY_0"; val = "gpg.program" }
  new { key = "GIT_CONFIG_VALUE_0"; val = "gpg" }
  new { key = "TERM"; val = "xterm-256color" }
  new {
    key = "GITHUB_TOKEN"
    valCmd = "pass github/token/for-agent"
  }
  new {
    key = "PATH"
    val = "~/.nix-profile/bin"
    mode = "suffix"
    separator = ":"
  }
  // for playwright-cli
  new {
    key = "PATH"
    val = "~/.local/share/pnpm"
    mode = "suffix"
    separator = ":"
  }
}

local function allow(h: String) = new ReviewRule { host = h; action = "allow" }
local function deny(h: String) = new ReviewRule { host = h; action = "deny" }

local commonNetwork: NetworkConfig = new {
  reviewRules {
    // --- deny (telemetry / 自動アクセス) ---
    // Claude Codeがなんか送ってるやつ
    deny("http-intake.logs.us5.datadoghq.com")
    // Chrome / Chromiumが勝手にアクセスするやつ
    deny("www.google.com")
    deny("mtalk.google.com")
    deny("clients2.google.com")
    deny("accounts.google.com")
    deny("android.clients.google.com")
    // Copilot CLIがなんか送ってるやつ
    deny("copilot-telemetry.githubusercontent.com")

    // --- allow ---
    // Anthropic / Claude
    for (h in List(
      "api.anthropic.com",
      "statsig.anthropic.com",
      "platform.claude.com",
      "mcp-proxy.anthropic.com",
      "code.claude.com",
      "claude.ai",
      "downloads.claude.ai"
    )) { allow(h) }

    // OpenAI / ChatGPT
    for (h in List(
      "api.openai.com",
      "*.api.openai.com",
      "ab.chatgpt.com",
      "chatgpt.com",
      "developers.openai.com"
    )) { allow(h) }

    // Google
    allow("storage.googleapis.com")

    // GitHub
    for (h in List(
      "api.github.com",
      "release-assets.githubusercontent.com",
      "codeload.github.com",
      "github.com",
      "gist.github.com",
      "raw.githubusercontent.com"
    )) { allow(h) }
    // Copilot
    for (h in List(
      "api.githubcopilot.com",
      "telemetry.individual.githubcopilot.com",
      "api.individual.githubcopilot.com",
      "telemetry.business.githubcopilot.com",
      "api.business.githubcopilot.com"
    )) { allow(h) }
    // 画像系
    allow("camo.githubusercontent.com")
    allow("avatars.githubusercontent.com")

    // Docker Hub
    for (h in List(
      "registry-1.docker.io",
      "auth.docker.io",
      "index.docker.io",
      "hub.docker.com",
      "www.docker.com",
      "production.cloudflare.docker.com",
      "download.docker.com"
    )) { allow(h) }

    // Container Registries
    allow("*.gcr.io")
    allow("ghcr.io")
    allow("mcr.microsoft.com")
    allow("*.data.mcr.microsoft.com")
    allow("public.ecr.aws")

    // Package Registries
    // nix
    for (h in List(
      "cache.iog.io",
      "cache.nixos.org",
      "channels.nixos.org"
    )) { allow(h) }
    // npm
    allow("registry.npmjs.org")
    // deno
    allow("jsr.io")
    allow("deno.land")
    // Rust
    allow("index.crates.io")
    allow("static.crates.io")

    // IETF Datatracker
    allow("datatracker.ietf.org")

    // catch-all: unmatched → pending (replaces prompt.enable = true)
    new { action = "review" }
  }
  proxy {
    forwardPorts = new Listing {
      8080
      5432
    }
  }
}

local commonHostexec: HostExecConfig = new {
  prompt {
    enable = true
    timeoutSeconds = 300
    defaultScope = "capability"
  }
  rules {
    new {
      id = "wl-paste"
      match {
        argv0 = "wl-paste"
      }
      cwd {
        mode = "workspace-or-session-tmp"
      }
      inheritEnv {
        mode = "minimal"
        keys = new Listing { "WAYLAND_DISPLAY"; "XDG_RUNTIME_DIR" }
      }
      approval = "allow"
      fallback = "container"
    }
    new {
      // git commit/tag -S が呼ぶ形だけを通す:
      //   gpg --status-fd=2 -bsau <keyid>
      id = "gpg-git-sign"
      match {
        argv0 = "gpg"
        argRegex = "^--status-fd=2 -bsau [0-9A-Fa-f]{8,40}$"
      }
      cwd {
        mode = "workspace-or-session-tmp"
      }
      approval = "allow"
      fallback = "container"
    }
    new {
      // mo の危険引数を遮断：
      //   --port/-p: forward-ports と衝突させるとホスト側 mo がコンテナから読める
      //   --bind/-b: 非ループバックへ bind されるとネットワーク越しに露出
      //   --dangerously-allow-remote-access: 安全プロンプトのバイパス
      //   絶対パス / ~ / .. を含む位置引数・値: workspace 外の host ファイル参照を禁止
      id = "mo-guard"
      match {
        argv0 = "mo"
        argRegex = #"((^|\s)(--port|-p|--bind|-b|--dangerously-allow-remote-access)(\s|=|$))|((^|\s|=)/)|((^|\s|=)~)|((^|\s|=|/)\.\.(\s|$|/))"#
      }
      cwd {
        mode = "workspace-or-session-tmp"
      }
      approval = "deny"
      fallback = "deny"
    }
    new {
      id = "mo"
      match {
        argv0 = "mo"
      }
      cwd {
        mode = "workspace-or-session-tmp"
      }
      approval = "allow"
      fallback = "container"
    }
  }
}

// common_infra + common_network + common_env + common_hostexec を含むベースプロファイル
local baseProfile: Profile = new {
  // Profile class は agent を required とする。各プロファイルで上書きする。
  agent = "claude"
  // common_infra
  nix {
    enable = "auto"
    mountSocket = true
  }
  session {
    multiplex = true
  }
  docker {
    enable = false
    shared = true
  }
  gcloud {
    mountConfig = false
  }
  aws {
    mountConfig = false
  }
  display {
    sandbox = "none"
  }
  gpg {
    forwardAgent = false
  }
  extraMounts {
    // gitignoreが居る
    new { src = "~/nix-config"; dst = "~/nix-config"; mode = "ro" }
    new { src = "~/.cache/nix-index/"; dst = "~/.cache/nix-index/"; mode = "ro" }
    new { src = "~/.nix-profile/bin"; dst = "~/.nix-profile/bin"; mode = "ro" }
    new { src = "~/.config/nvim"; dst = "~/.config/nvim"; mode = "ro" }
    new { src = "~/.config/tmux"; dst = "~/.config/tmux"; mode = "ro" }
    new { src = "~/.local/share/nvim"; dst = "~/.local/share/nvim"; mode = "ro" }
  }
  network = commonNetwork
  env = commonEnv
  hostexec = commonHostexec
}

// ---------------------------------------------------------------------------
// Top-level config
// ---------------------------------------------------------------------------

default = "claude"

ui {
  enable = true
  port = 3939
  idleTimeout = 300
}

observability {
  enable = true
}

profiles {
  ["claude"] = (baseProfile) {
    agent = "claude"
    agentArgs = new Listing { "--dangerously-skip-permissions" }
  }

  ["codex"] = (baseProfile) {
    agent = "codex"
    agentArgs = new Listing { "--dangerously-bypass-approvals-and-sandbox" }
    dbus {
      session {
        enable = true
        calls {
          new { name = "org.freedesktop.secrets"; rule = "org.freedesktop.Secret.Service.OpenSession" }
          new { name = "org.freedesktop.secrets"; rule = "org.freedesktop.Secret.Service.SearchItems" }
          new { name = "org.freedesktop.secrets"; rule = "org.freedesktop.Secret.Item.GetSecret" }
        }
      }
    }
  }

  ["copilot"] = (baseProfile) {
    agent = "copilot"
    agentArgs = new Listing { "--allow-all" }
  }
}
